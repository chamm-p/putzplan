# Host-Port (Container intern bleibt 8000)
APP_PORT=7801

# Stark wählen in Prod: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me

# Registrierung neuer User per User/Pass erlauben
REGISTRATION_ENABLED=true

# Session-JWT Lifetime (Tage)
TOKEN_EXPIRE_DAYS=60

# Keycloak / OIDC (optional)
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://kc.example.com/realms/myrealm
OIDC_CLIENT_ID=putzplan
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://putz.example.com/api/auth/oidc/callback
OIDC_SCOPES=openid email profile
OIDC_BUTTON_LABEL=Mit Keycloak anmelden

# LLM (OpenAI-kompatibler Chat/Completions Endpunkt)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

# Speech-to-Text (OpenAI-kompatibler Transcription Endpunkt)
STT_BASE_URL=https://api.openai.com/v1
STT_API_KEY=sk-...
STT_MODEL=whisper-1
